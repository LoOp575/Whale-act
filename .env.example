# =========================================================
# WHALECOPY AI - ENV EXAMPLE
# Copy this file to .env.local for local development.
# Fill real values in Codespace/Vercel secrets only.
# NEVER commit .env.local or real API keys.
# =========================================================

# APP CONFIG
NEXT_PUBLIC_APP_URL=https://whale-act-7zm1.vercel.app
APP_ENV=production
PAPER_TRADING=true
LIVE_TRADING_ENABLED=false
TRADING_MODE=PAPER_ONLY

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# HELIUS - SOLANA WALLET TRACKING
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=wcai_9f7xK2mQp8sL2026

# DEX SCREENER - MARKET DATA
DEXSCREENER_BASE_URL=https://api.dexscreener.com

# AI PROVIDER - AICHIXIA / OPENAI COMPATIBLE
AI_PROVIDER=openai-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://www.aichixia.xyz/api/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=800

# SCANNER SETTINGS
CHAIN_ID=solana
SCAN_INTERVAL_SECONDS=20
MIN_LIQUIDITY_USD=20000
MIN_WALLET_SCORE=75
MAX_PRICE_PUMP_5M=40
MAX_SLIPPAGE_BPS=150

# WALLET SCORING SETTINGS
MIN_ROI_24H=50
MIN_WINRATE_7D=55
MIN_TRADE_COUNT_24H=3
MAX_RISK_SCORE=60

# PAPER TRADING SETTINGS
MAX_PAPER_TRADE_USD=10
MAX_DAILY_LOSS_USD=20
MAX_OPEN_POSITIONS=2
STOP_LOSS_PERCENT=-6
TAKE_PROFIT_1_PERCENT=8
TAKE_PROFIT_2_PERCENT=15
TRAILING_STOP_ENABLED=true
TRAILING_STOP_TRIGGER_PERCENT=12
TRAILING_STOP_DROP_PERCENT=5

# SAFETY GUARD
AUTO_TRADE_REQUIRES_CONFIRMATION=true
EMERGENCY_STOP=false
ALLOW_PRIVATE_KEY_INPUT=false
ALLOW_LIVE_SWAP=false
ALLOW_REAL_BUY=false
ALLOW_REAL_SELL=false

# PRODUCTION SETTINGS
ENABLE_DEV_SIMULATOR=false
ENABLE_MOCK_FALLBACK=false
LOG_AGENT_DEBUG=true

# =========================================================
