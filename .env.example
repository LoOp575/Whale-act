# ============================================================
# WhaleCopy AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# App runs with mock data if these are not set.
# ============================================================

# --- Supabase (Database & Auth) ---
# Public keys (safe for frontend)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret (NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=

# --- Helius (Solana RPC + Enhanced API) ---
# Get key from https://helius.dev
HELIUS_API_KEY=

# --- AI Provider (OpenAI-Compatible) ---
# Supports: OpenAI, Aixchia, Azure, local LLMs, etc.
AI_PROVIDER=openai-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=300

# Examples:
# OpenAI official:  OPENAI_BASE_URL= (leave empty, uses default)
# Aixchia:          OPENAI_BASE_URL=https://api.aixchia.com
# Local LLM:       OPENAI_BASE_URL=http://localhost:1234

# --- DexScreener (Token Market Data) ---
# Public API, no key required
DEXSCREENER_BASE_URL=https://api.dexscreener.com

# --- App Mode ---
# true = paper trading only (no real funds)
# false = NOT SUPPORTED in this version
PAPER_TRADING=true

# ============================================================
# IMPORTANT RULES:
# - Never commit .env.local to git
# - SUPABASE_SERVICE_ROLE_KEY is server-side only
# - OPENAI_API_KEY is server-side only
# - No private wallet keys — we don't do live trading
# - App falls back to mock data if env is empty
# ============================================================
